# ===========================================
# ThooviTickets Environment Variables
# Copy this file to .env and fill in values
# ===========================================

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/thoovitickets

# JWT Secrets (generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY_ADMIN=5h
JWT_REFRESH_EXPIRY_ORGANISER=12h
JWT_REFRESH_EXPIRY_CUSTOMER=24h


# App Config
PORT=4000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development

# Admin Seed User
ADMIN_EMAIL=admin@thoovitickets.com
ADMIN_PASSWORD=Admin@123456

# Email - Resend (primary)
RESEND_API_KEY=RESEND_API_KEY
RESEND_FROM_EMAIL=RESEND_FROM_EMAIL

# Email - Gmail SMTP (fallback, optional)
# Generate App Password: Google Account > Security > 2FA > App Passwords
GMAIL_USER=GMAIL_USER_email
GMAIL_APP_PASSWORD=GMAIL_APP_PASSWORD

# Supabase Storage (file uploads)
SUPABASE_URL=SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=SUPABASE_SERVICE_ROLE_KEY


# Razorpay (optional - uses mock provider if not set)
# Get test keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=RAZORPAY_KEY_SECRET
RAZORPAY_WEBHOOK_SECRET=xxxxx

# Google Gemini AI (optional - AI features disabled if not set)
# Get API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
