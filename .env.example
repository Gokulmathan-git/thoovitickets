# ===========================================
# ThooviTickets Environment Variables
# Copy this file to .env and fill in values
# ===========================================

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/thoovitickets

# JWT Secrets (generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# App Config
PORT=4000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Admin Seed User
ADMIN_EMAIL=admin@thoovitickets.com
ADMIN_PASSWORD=Admin@123456

# Razorpay (optional - uses mock provider if not set)
# Get test keys from https://dashboard.razorpay.com/app/keys
# RAZORPAY_KEY_ID=rzp_test_T2gOLsARsDXTKT
# RAZORPAY_KEY_SECRET=NkBBVwMfOG3Z7PEsE3R6EaZI
# RAZORPAY_WEBHOOK_SECRET=xxxxx
