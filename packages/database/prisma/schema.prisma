generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────

enum UserRole {
  CUSTOMER
  ORGANISER
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum EventStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PUBLISHED
  POSTPONED
  CANCELLED
  COMPLETED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum SubscriptionTier {
  FREE
  PRO
  ADVANCE
  ENTERPRISE
}

enum StaffAccessLevel {
  SCANNER
  SUB_ADMIN
  FULL_ACCESS
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum DiscountType {
  FIXED
  PERCENTAGE
}

enum SettlementStatus {
  PENDING
  REQUESTED
  PROCESSING
  COMPLETED
  REJECTED
}

enum ApprovalType {
  USER_REGISTRATION
  USER_REACTIVATION
  EVENT_PUBLISH
  EVENT_CANCEL
  EVENT_POSTPONE
}

enum ApprovalAction {
  PENDING
  APPROVED
  REJECTED
}

enum TicketStatus {
  ACTIVE
  USED
  CANCELLED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── PLATFORM CONFIG ─────────────────────────────────

model PlatformConfig {
  id                    String  @id @default(cuid())
  platformFeePercent    Decimal @db.Decimal(5, 2) @default(3.00) @map("platform_fee_percent")
  defaultOrgCommission  Decimal @db.Decimal(5, 2) @default(2.00) @map("default_org_commission")
  gstNumber             String? @map("gst_number")
  panNumber             String? @map("pan_number")
  companyName           String? @map("company_name")
  companyAddress        String? @map("company_address")

  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("platform_config")
}

// ─── MODELS ──────────────────────────────────────────

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  passwordHash   String     @map("password_hash")
  firstName      String     @map("first_name")
  lastName       String     @map("last_name")
  phone          String?
  role           UserRole   @default(CUSTOMER)
  status         UserStatus @default(ACTIVE)
  emailVerified  Boolean    @default(false) @map("email_verified")
  avatarUrl      String?    @map("avatar_url")
  refreshToken   String?    @map("refresh_token")

  statusReason   String?    @map("status_reason")

  orgName              String?    @map("org_name")
  orgDescription       String?    @map("org_description")
  orgCommissionPercent Decimal?   @db.Decimal(5, 2) @map("org_commission_percent")
  orgCommissionType    String?    @map("org_commission_type")
  idDocumentUrl        String?    @map("id_document_url")
  idDocumentType       String?    @map("id_document_type")
  aadharDocumentUrl    String?    @map("aadhar_document_url")
  panDocumentUrl       String?    @map("pan_document_url")
  gstNumber            String?    @map("gst_number")
  profileCompleted     Boolean    @default(false) @map("profile_completed")
  orgTerms             String?    @map("org_terms") @db.Text
  resetToken           String?    @map("reset_token")
  resetTokenExpiry     DateTime?  @map("reset_token_expiry")
  emailVerificationToken       String?    @map("email_verification_token")
  emailVerificationTokenExpiry DateTime?  @map("email_verification_token_expiry")

  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  events              Event[]
  orders              Order[]
  cart                Cart?
  subscriptions       OrgSubscription[]
  approvalsRequested  AdminApproval[] @relation("ApprovalRequester")
  approvalsReviewed   AdminApproval[] @relation("ApprovalReviewer")
  staffCreated        StaffAccount[]  @relation("OrganiserStaff")
  staffAccess         StaffAccount[]  @relation("StaffUser")
  platformReviews     PlatformReview[]
  eventReviews        EventReview[]
  subscriptionPayments SubscriptionPayment[]
  discounts            Discount[] @relation("OrganiserDiscounts")
  settlements          Settlement[] @relation("OrganiserSettlements")
  gstBills             GstBill[]    @relation("OrganiserGstBills")
  notifications        Notification[]
  termsAcceptances     TermsAcceptance[]
  products             Product[]
  referralCode         String?          @unique @map("referral_code")
  referredByUserId     String?          @map("referred_by_user_id")
  referralsMade        Referral[]       @relation("ReferralsMade")
  referralsReceived    Referral[]       @relation("ReferralsReceived")
  thoviPointsWallet    ThoviPointsWallet?

  @@map("users")
}

model EventCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  events      Event[]

  @@map("event_categories")
}

model Event {
  id           String      @id @default(cuid())
  title        String
  slug         String      @unique
  description  String
  shortDesc    String?     @map("short_desc")
  venue        String
  address      String?
  city         String
  state        String?
  country      String      @default("India")
  latitude     Float?
  longitude    Float?
  startDate    DateTime    @map("start_date")
  endDate      DateTime    @map("end_date")
  imageUrl     String?     @map("image_url")
  bannerUrl    String?     @map("banner_url")
  status       EventStatus @default(DRAFT)
  isFeatured   Boolean     @default(false) @map("is_featured")
  showOnHomeBanner Boolean  @default(false) @map("show_on_home_banner")
  homeBannerUrl    String?  @map("home_banner_url")
  homeBannerTitle  String?  @map("home_banner_title")
  homeBannerDesc   String?  @map("home_banner_desc")
  maxAttendees Int?        @map("max_attendees")
  tags         String[]    @default([])
  timezone     String      @default("Asia/Kolkata")
  saleCutoffDate DateTime? @map("sale_cutoff_date")
  cancelledAt  DateTime?   @map("cancelled_at")
  cancelReason String?     @map("cancel_reason")
  postponedFrom DateTime?  @map("postponed_from")
  postponeMessage String?  @map("postpone_message")
  commissionPercent Decimal? @db.Decimal(5, 2) @map("commission_percent")
  commissionType    String?  @map("commission_type")

  organiserId  String      @map("organiser_id")
  categoryId   String      @map("category_id")

  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  organiser    User          @relation(fields: [organiserId], references: [id])
  category     EventCategory @relation(fields: [categoryId], references: [id])
  ticketTypes  TicketType[]
  orderItems   OrderItem[]
  approvals    AdminApproval[]
  eventReviews EventReview[]
  homeBanners  HomeBanner[]
  discounts    Discount[]
  settlements  Settlement[]
  referrals    Referral[]

  @@index([organiserId])
  @@index([categoryId])
  @@index([status])
  @@index([startDate])
  @@index([city])
  @@map("events")
}

model TicketType {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("INR")
  totalQty    Int      @map("total_qty")
  soldQty     Int      @default(0) @map("sold_qty")
  maxPerOrder Int      @default(5) @map("max_per_order")
  saleStart   DateTime? @map("sale_start")
  saleEnd     DateTime? @map("sale_end")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")

  eventId     String   @map("event_id")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  cartItems   CartItem[]
  orderItems    OrderItem[]
  discountLinks DiscountTicketType[]
  goodies       TicketGoodie[]

  @@index([eventId])
  @@map("ticket_types")
}

model AdminApproval {
  id           String         @id @default(cuid())
  type         ApprovalType
  action       ApprovalAction @default(PENDING)
  reason       String?
  notes        String?
  metadata     Json?

  requesterId  String         @map("requester_id")
  reviewerId   String?        @map("reviewer_id")
  eventId      String?        @map("event_id")

  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  requester    User           @relation("ApprovalRequester", fields: [requesterId], references: [id])
  reviewer     User?          @relation("ApprovalReviewer", fields: [reviewerId], references: [id])
  event        Event?         @relation(fields: [eventId], references: [id])

  @@index([type, action])
  @@map("admin_approvals")
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique @map("user_id")
  expiresAt DateTime?  @map("expires_at")

  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@map("carts")
}

model CartItem {
  id           String     @id @default(cuid())
  quantity     Int
  cartId       String     @map("cart_id")
  ticketTypeId String     @map("ticket_type_id")

  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  cart         Cart       @relation(fields: [cartId], references: [id], onDelete: Cascade)
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id])

  @@unique([cartId, ticketTypeId])
  @@map("cart_items")
}

model Order {
  id                String      @id @default(cuid())
  orderNumber       String      @unique @map("order_number")
  status            OrderStatus @default(PENDING)
  subtotal          Decimal     @db.Decimal(10, 2) @default(0) @map("subtotal")
  platformFee       Decimal     @db.Decimal(10, 2) @default(0) @map("platform_fee")
  platformFeePercent Decimal    @db.Decimal(5, 2) @default(0) @map("platform_fee_percent")
  totalAmount       Decimal     @db.Decimal(10, 2) @map("total_amount")
  orgCommission     Decimal     @db.Decimal(10, 2) @default(0) @map("org_commission")
  orgCommissionPercent Decimal  @db.Decimal(5, 2) @default(0) @map("org_commission_percent")
  orgCommissionType String?     @map("org_commission_type")
  orgPayout         Decimal     @db.Decimal(10, 2) @default(0) @map("org_payout")
  convenienceFee    Decimal     @db.Decimal(10, 2) @default(0) @map("convenience_fee")
  convenienceFeeType String?    @map("convenience_fee_type")
  currency          String      @default("INR")
  guestEmail        String?     @map("guest_email")
  guestName         String?     @map("guest_name")
  guestPhone        String?     @map("guest_phone")
  discountId        String?     @map("discount_id")
  discountCode      String?     @map("discount_code")
  discountAmount    Decimal     @db.Decimal(10, 2) @default(0) @map("discount_amount")

  userId            String?     @map("user_id")

  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  expiresAt      DateTime?   @map("expires_at")

  attendeeData   Json?       @map("attendee_data")
  invoiceUrl     String?     @map("invoice_url")

  user           User?       @relation(fields: [userId], references: [id])
  items          OrderItem[]
  tickets        Ticket[]
  payment        Payment?
  platformReview PlatformReview?
  eventReviews   EventReview[]
  discount       Discount?    @relation(fields: [discountId], references: [id])

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id           String     @id @default(cuid())
  quantity     Int
  unitPrice    Decimal    @db.Decimal(10, 2) @map("unit_price")
  totalPrice          Decimal    @db.Decimal(10, 2) @map("total_price")
  discountedUnitPrice Decimal?   @db.Decimal(10, 2) @map("discounted_unit_price")

  orderId      String     @map("order_id")
  ticketTypeId String     @map("ticket_type_id")
  eventId      String     @map("event_id")

  createdAt    DateTime   @default(now()) @map("created_at")

  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id])
  event        Event      @relation(fields: [eventId], references: [id])
  tickets      Ticket[]

  @@map("order_items")
}

model Payment {
  id                String        @id @default(cuid())
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("INR")
  status            PaymentStatus @default(PENDING)
  provider          String        @default("manual")
  providerPaymentId String?       @map("provider_payment_id")
  providerOrderId   String?       @map("provider_order_id")
  metadata          Json?
  failureReason     String?       @map("failure_reason")

  orderId           String        @unique @map("order_id")

  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  order             Order         @relation(fields: [orderId], references: [id])

  @@index([providerPaymentId])
  @@map("payments")
}

model Discount {
  id              String       @id @default(cuid())
  code            String
  discountType    DiscountType @map("discount_type")
  value           Decimal      @db.Decimal(10, 2)
  maxUses         Int?         @map("max_uses")
  usedCount       Int          @default(0) @map("used_count")
  startDate       DateTime     @map("start_date")
  endDate         DateTime     @map("end_date")
  isActive        Boolean      @default(true) @map("is_active")
  isPublic        Boolean      @default(true) @map("is_public")

  eventId         String       @map("event_id")
  organiserId     String       @map("organiser_id")

  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  event           Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organiser       User         @relation("OrganiserDiscounts", fields: [organiserId], references: [id])
  ticketTypes     DiscountTicketType[]
  orders          Order[]

  @@unique([code, eventId])
  @@index([eventId])
  @@index([organiserId])
  @@index([code])
  @@map("discounts")
}

model DiscountTicketType {
  id            String     @id @default(cuid())
  discountId    String     @map("discount_id")
  ticketTypeId  String     @map("ticket_type_id")

  discount      Discount   @relation(fields: [discountId], references: [id], onDelete: Cascade)
  ticketType    TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)

  @@unique([discountId, ticketTypeId])
  @@map("discount_ticket_types")
}

model Settlement {
  id              String           @id @default(cuid())
  amount          Decimal          @db.Decimal(10, 2)
  platformFee     Decimal          @db.Decimal(10, 2) @default(0) @map("platform_fee")
  commission      Decimal          @db.Decimal(10, 2) @default(0)
  netPayout       Decimal          @db.Decimal(10, 2) @map("net_payout")
  status          SettlementStatus @default(PENDING)
  requestedAt     DateTime?        @map("requested_at")
  processedAt     DateTime?        @map("processed_at")
  rejectedAt      DateTime?        @map("rejected_at")
  rejectionReason String?          @map("rejection_reason")
  transactionRef  String?          @map("transaction_ref")
  notes           String?

  organiserId     String           @map("organiser_id")
  eventId         String           @map("event_id")

  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  organiser       User             @relation("OrganiserSettlements", fields: [organiserId], references: [id])
  event           Event            @relation(fields: [eventId], references: [id])
  gstBills        GstBill[]

  @@index([organiserId])
  @@index([eventId])
  @@index([status])
  @@map("settlements")
}

model Ticket {
  id            String       @id @default(cuid())
  ticketCode    String       @unique @map("ticket_code")
  status        TicketStatus @default(ACTIVE)
  attendeeName  String       @map("attendee_name")
  attendeeEmail String       @map("attendee_email")
  attendeePhone String       @map("attendee_phone")
  qrData        String       @map("qr_data")
  qrDataUrl     String?      @map("qr_data_url") @db.Text
  checkedInAt   DateTime?    @map("checked_in_at")
  goodiesData   Json?        @map("goodies_data")

  orderItemId   String       @map("order_item_id")
  orderId       String       @map("order_id")

  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  orderItem     OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  order         Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([orderItemId])
  @@index([ticketCode])
  @@map("tickets")
}

model Plan {
  id                 String   @id @default(cuid())
  tier               String   @unique
  name               String
  price              Decimal  @db.Decimal(10, 2)
  priceQuarterly     Decimal? @db.Decimal(10, 2) @map("price_quarterly")
  priceHalfYearly    Decimal? @db.Decimal(10, 2) @map("price_half_yearly")
  priceYearly        Decimal? @db.Decimal(10, 2) @map("price_yearly")
  maxEventsPerMonth  Int      @map("max_events_per_month")
  maxTicketTiers     Int      @map("max_ticket_tiers")
  maxTicketsPerEvent Int      @map("max_tickets_per_event")
  maxStaffAccounts   Int      @map("max_staff_accounts")
  commissionPercent  Decimal  @db.Decimal(5, 2) @map("commission_percent")
  commissionType     String   @default("PERCENTAGE") @map("commission_type")
  features           String[] @default([])
  isActive           Boolean  @default(true) @map("is_active")
  sortOrder          Int      @default(0) @map("sort_order")

  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  subscriptions      OrgSubscription[]
  subscriptionPayments SubscriptionPayment[]

  @@map("plans")
}

model OrgSubscription {
  id                 String             @id @default(cuid())
  tier               SubscriptionTier   @default(FREE)
  status             SubscriptionStatus @default(ACTIVE)
  maxEvents          Int                @map("max_events")
  maxTickets         Int                @map("max_tickets")
  maxTicketTiers     Int                @default(2) @map("max_ticket_tiers")
  maxStaffAccounts   Int                @default(1) @map("max_staff_accounts")
  commissionPercent  Decimal            @db.Decimal(5, 2) @default(4.00) @map("commission_percent")
  commissionType     String             @default("PERCENTAGE") @map("commission_type")
  price              Decimal            @db.Decimal(10, 2) @default(0)
  billingCycle       String?            @map("billing_cycle")
  startDate          DateTime           @map("start_date")
  endDate            DateTime?          @map("end_date")

  userId             String             @map("user_id")
  planId             String?            @map("plan_id")
  scheduledPlanId    String?            @map("scheduled_plan_id")
  scheduledPlanTier  String?            @map("scheduled_plan_tier")

  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  user               User               @relation(fields: [userId], references: [id])
  plan               Plan?              @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([userId, status])
  @@map("org_subscriptions")
}

model SubscriptionPayment {
  id                String        @id @default(cuid())
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("INR")
  status            PaymentStatus @default(PENDING)
  provider          String        @default("manual")
  providerPaymentId String?       @map("provider_payment_id")
  providerOrderId   String?       @map("provider_order_id")
  metadata          Json?
  failureReason     String?       @map("failure_reason")

  userId            String        @map("user_id")
  planId            String        @map("plan_id")
  tier              String
  billingCycle      String?       @map("billing_cycle")
  activateNow       Boolean       @default(true) @map("activate_now")

  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  user              User          @relation(fields: [userId], references: [id])
  plan              Plan          @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([providerOrderId])
  @@map("subscription_payments")
}

model StaffAccount {
  id            String           @id @default(cuid())
  accessLevel   StaffAccessLevel @map("access_level")
  isActive      Boolean          @default(true) @map("is_active")

  organiserId   String           @map("organiser_id")
  userId        String           @map("user_id")

  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  organiser     User             @relation("OrganiserStaff", fields: [organiserId], references: [id])
  user          User             @relation("StaffUser", fields: [userId], references: [id])

  @@unique([organiserId, userId])
  @@index([userId])
  @@map("staff_accounts")
}

model ContentPage {
  id        String   @id @default(cuid())
  slug      String
  audience  String
  title     String
  content   String   @db.Text
  isActive  Boolean  @default(true) @map("is_active")

  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([slug, audience])
  @@map("content_pages")
}

model ConvenienceFeeSlab {
  id        String   @id @default(cuid())
  minAmount Decimal  @db.Decimal(10, 2) @map("min_amount")
  maxAmount Decimal? @db.Decimal(10, 2) @map("max_amount")
  feeType   String   @map("fee_type")
  feeValue  Decimal  @db.Decimal(10, 2) @map("fee_value")
  isActive  Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("convenience_fee_slabs")
}

// ─── PLATFORM REVIEWS ───────────────────────────────

model PlatformReview {
  id          String       @id @default(cuid())
  rating      Int
  title       String?
  content     String       @db.Text
  status      ReviewStatus @default(PENDING)
  isVisible   Boolean      @default(false) @map("is_visible")
  adminNotes  String?      @map("admin_notes")
  reviewedBy  String?      @map("reviewed_by")
  reviewedAt  DateTime?    @map("reviewed_at")

  userId      String       @map("user_id")
  orderId     String       @unique @map("order_id")

  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id])
  order       Order        @relation(fields: [orderId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([isVisible])
  @@map("platform_reviews")
}

// ─── EVENT REVIEWS ──────────────────────────────────

model EventReview {
  id          String       @id @default(cuid())
  rating      Int
  title       String?
  content     String       @db.Text
  isVisible   Boolean      @default(true) @map("is_visible")

  userId      String       @map("user_id")
  eventId     String       @map("event_id")
  orderId     String       @map("order_id")

  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id])
  event       Event        @relation(fields: [eventId], references: [id])
  order       Order        @relation(fields: [orderId], references: [id])

  @@unique([userId, eventId])
  @@index([eventId])
  @@index([isVisible])
  @@map("event_reviews")
}

model HomeBanner {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String   @map("image_url")
  linkType    String   @default("none") @map("link_type") // "none" | "url" | "event"
  linkUrl     String?  @map("link_url")
  eventId     String?  @map("event_id")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  event       Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([isActive, sortOrder])
  @@map("home_banners")
}

// ─── NOTIFICATIONS ──────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String
  linkUrl   String?  @map("link_url")
  isRead    Boolean  @default(false) @map("is_read")

  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

// ─── TERMS ACCEPTANCE ───────────────────────────────

model TermsAcceptance {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  contentPageId   String   @map("content_page_id")
  contentVersion  DateTime @map("content_version")
  ipAddress       String?  @map("ip_address")
  userAgent       String?  @map("user_agent") @db.Text
  acceptedAt      DateTime @default(now()) @map("accepted_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([contentPageId])
  @@map("terms_acceptances")
}

// ─── PRODUCTS / GOODIES ─────────────────────────────

model Product {
  id             String   @id @default(cuid())
  name           String
  description    String?
  imageUrl       String?  @map("image_url")
  hasSizeVariant Boolean  @default(false) @map("has_size_variant")
  isActive       Boolean  @default(true) @map("is_active")

  organiserId    String   @map("organiser_id")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organiser      User     @relation(fields: [organiserId], references: [id])
  variants       ProductVariant[]
  ticketGoodies  TicketGoodie[]

  @@index([organiserId])
  @@map("products")
}

model ProductVariant {
  id        String  @id @default(cuid())
  size      String?

  productId String  @map("product_id")

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_variants")
}

model TicketGoodie {
  id           String     @id @default(cuid())

  ticketTypeId String     @map("ticket_type_id")
  productId    String     @map("product_id")

  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([ticketTypeId, productId])
  @@map("ticket_goodies")
}

model GstBill {
  id              String   @id @default(cuid())
  billNumber      String   @unique @map("bill_number")
  billDate        DateTime @map("bill_date")

  companyName     String   @default("ThooviTickets") @map("company_name")
  companyGst      String?  @map("company_gst")
  companyPan      String?  @map("company_pan")
  companyAddress  String?  @map("company_address") @db.Text

  organiserId     String   @map("organiser_id")
  settlementId    String?  @map("settlement_id")

  orgName         String   @map("org_name")
  orgGstNumber    String?  @map("org_gst_number")
  orgAddress      String?  @map("org_address")

  description     String   @db.Text
  hsnCode         String?  @map("hsn_code")
  quantity        Int      @default(1)
  rate            Decimal  @db.Decimal(10, 2)
  taxableAmount   Decimal  @db.Decimal(10, 2) @map("taxable_amount")
  cgstPercent     Decimal  @db.Decimal(5, 2) @default(9) @map("cgst_percent")
  cgstAmount      Decimal  @db.Decimal(10, 2) @map("cgst_amount")
  sgstPercent     Decimal  @db.Decimal(5, 2) @default(9) @map("sgst_percent")
  sgstAmount      Decimal  @db.Decimal(10, 2) @map("sgst_amount")
  igstPercent     Decimal  @db.Decimal(5, 2) @default(0) @map("igst_percent")
  igstAmount      Decimal  @db.Decimal(10, 2) @default(0) @map("igst_amount")
  totalAmount     Decimal  @db.Decimal(10, 2) @map("total_amount")
  amountInWords   String?  @map("amount_in_words")

  notes           String?  @db.Text

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organiser       User     @relation("OrganiserGstBills", fields: [organiserId], references: [id])
  settlement      Settlement? @relation(fields: [settlementId], references: [id])

  @@index([organiserId])
  @@index([settlementId])
  @@index([billNumber])
  @@map("gst_bills")
}

// ─── REFERRAL & THOOVI POINTS ────────────────────────

enum ReferralStatus {
  PENDING
  QUALIFIED
  REWARDED
  REJECTED
}

enum PointsTransactionType {
  REFERRAL_REWARD
  MILESTONE_BONUS
  SUBSCRIPTION_REDEMPTION
  FEATURED_LISTING
  PLATFORM_FEE_REDEMPTION
  ADMIN_CREDIT
  ADMIN_DEBIT
  EXPIRED
}

model Referral {
  id                String         @id @default(cuid())
  referralCode      String         @map("referral_code")
  status            ReferralStatus @default(PENDING)

  referrerId        String         @map("referrer_id")
  referredId        String         @map("referred_id")
  qualifyingEventId String?        @map("qualifying_event_id")

  grossTicketSales  Decimal?       @db.Decimal(12, 2) @map("gross_ticket_sales")
  rewardPoints      Int?           @map("reward_points")
  referralNumber    Int?           @map("referral_number")

  qualifiedAt       DateTime?      @map("qualified_at")
  rewardedAt        DateTime?      @map("rewarded_at")
  rejectedAt        DateTime?      @map("rejected_at")
  rejectionReason   String?        @map("rejection_reason")

  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  referrer          User           @relation("ReferralsMade", fields: [referrerId], references: [id])
  referred          User           @relation("ReferralsReceived", fields: [referredId], references: [id])
  qualifyingEvent   Event?         @relation(fields: [qualifyingEventId], references: [id])

  @@unique([referrerId, referredId])
  @@index([referrerId])
  @@index([referredId])
  @@index([status])
  @@index([referralCode])
  @@map("referrals")
}

model ThoviPointsWallet {
  id           String   @id @default(cuid())
  balance      Int      @default(0)
  totalEarned  Int      @default(0) @map("total_earned")
  totalSpent   Int      @default(0) @map("total_spent")

  userId       String   @unique @map("user_id")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user         User     @relation(fields: [userId], references: [id])
  transactions PointsTransaction[]

  @@map("thovi_points_wallets")
}

model PointsTransaction {
  id          String                @id @default(cuid())
  type        PointsTransactionType
  points      Int
  balance     Int
  description String

  walletId    String                @map("wallet_id")
  referralId  String?               @map("referral_id")

  createdAt   DateTime              @default(now()) @map("created_at")

  wallet      ThoviPointsWallet     @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([type])
  @@map("points_transactions")
}
