generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────

enum UserRole {
  CUSTOMER
  ORGANISER
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum EventStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PUBLISHED
  POSTPONED
  CANCELLED
  COMPLETED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum SubscriptionTier {
  FREE
  PRO
  ADVANCE
  ENTERPRISE
}

enum StaffAccessLevel {
  SCANNER
  SUB_ADMIN
  FULL_ACCESS
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum ApprovalType {
  USER_REGISTRATION
  USER_REACTIVATION
  EVENT_PUBLISH
  EVENT_CANCEL
  EVENT_POSTPONE
}

enum ApprovalAction {
  PENDING
  APPROVED
  REJECTED
}

enum TicketStatus {
  ACTIVE
  USED
  CANCELLED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── PLATFORM CONFIG ─────────────────────────────────

model PlatformConfig {
  id                    String  @id @default(cuid())
  platformFeePercent    Decimal @db.Decimal(5, 2) @default(3.00) @map("platform_fee_percent")
  defaultOrgCommission  Decimal @db.Decimal(5, 2) @default(2.00) @map("default_org_commission")
  gstNumber             String? @map("gst_number")
  panNumber             String? @map("pan_number")
  companyName           String? @map("company_name")
  companyAddress        String? @map("company_address")

  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("platform_config")
}

// ─── MODELS ──────────────────────────────────────────

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  passwordHash   String     @map("password_hash")
  firstName      String     @map("first_name")
  lastName       String     @map("last_name")
  phone          String?
  role           UserRole   @default(CUSTOMER)
  status         UserStatus @default(ACTIVE)
  emailVerified  Boolean    @default(false) @map("email_verified")
  avatarUrl      String?    @map("avatar_url")
  refreshToken   String?    @map("refresh_token")

  statusReason   String?    @map("status_reason")

  orgName              String?    @map("org_name")
  orgDescription       String?    @map("org_description")
  orgCommissionPercent Decimal?   @db.Decimal(5, 2) @map("org_commission_percent")
  orgCommissionType    String?    @map("org_commission_type")
  idDocumentUrl        String?    @map("id_document_url")
  idDocumentType       String?    @map("id_document_type")
  aadharDocumentUrl    String?    @map("aadhar_document_url")
  panDocumentUrl       String?    @map("pan_document_url")
  gstNumber            String?    @map("gst_number")
  profileCompleted     Boolean    @default(false) @map("profile_completed")
  resetToken           String?    @map("reset_token")
  resetTokenExpiry     DateTime?  @map("reset_token_expiry")
  emailVerificationToken       String?    @map("email_verification_token")
  emailVerificationTokenExpiry DateTime?  @map("email_verification_token_expiry")

  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  events              Event[]
  orders              Order[]
  cart                Cart?
  subscriptions       OrgSubscription[]
  approvalsRequested  AdminApproval[] @relation("ApprovalRequester")
  approvalsReviewed   AdminApproval[] @relation("ApprovalReviewer")
  staffCreated        StaffAccount[]  @relation("OrganiserStaff")
  staffAccess         StaffAccount[]  @relation("StaffUser")
  platformReviews     PlatformReview[]
  eventReviews        EventReview[]
  subscriptionPayments SubscriptionPayment[]

  @@map("users")
}

model EventCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  events      Event[]

  @@map("event_categories")
}

model Event {
  id           String      @id @default(cuid())
  title        String
  slug         String      @unique
  description  String
  shortDesc    String?     @map("short_desc")
  venue        String
  address      String?
  city         String
  state        String?
  country      String      @default("India")
  latitude     Float?
  longitude    Float?
  startDate    DateTime    @map("start_date")
  endDate      DateTime    @map("end_date")
  imageUrl     String?     @map("image_url")
  bannerUrl    String?     @map("banner_url")
  status       EventStatus @default(DRAFT)
  isFeatured   Boolean     @default(false) @map("is_featured")
  showOnHomeBanner Boolean  @default(false) @map("show_on_home_banner")
  homeBannerUrl    String?  @map("home_banner_url")
  homeBannerTitle  String?  @map("home_banner_title")
  homeBannerDesc   String?  @map("home_banner_desc")
  maxAttendees Int?        @map("max_attendees")
  tags         String[]    @default([])
  timezone     String      @default("Asia/Kolkata")
  saleCutoffDate DateTime? @map("sale_cutoff_date")
  cancelledAt  DateTime?   @map("cancelled_at")
  cancelReason String?     @map("cancel_reason")
  postponedFrom DateTime?  @map("postponed_from")
  postponeMessage String?  @map("postpone_message")
  commissionPercent Decimal? @db.Decimal(5, 2) @map("commission_percent")
  commissionType    String?  @map("commission_type")

  organiserId  String      @map("organiser_id")
  categoryId   String      @map("category_id")

  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  organiser    User          @relation(fields: [organiserId], references: [id])
  category     EventCategory @relation(fields: [categoryId], references: [id])
  ticketTypes  TicketType[]
  orderItems   OrderItem[]
  approvals    AdminApproval[]
  eventReviews EventReview[]

  @@index([organiserId])
  @@index([categoryId])
  @@index([status])
  @@index([startDate])
  @@index([city])
  @@map("events")
}

model TicketType {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("INR")
  totalQty    Int      @map("total_qty")
  soldQty     Int      @default(0) @map("sold_qty")
  maxPerOrder Int      @default(5) @map("max_per_order")
  saleStart   DateTime? @map("sale_start")
  saleEnd     DateTime? @map("sale_end")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")

  eventId     String   @map("event_id")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@index([eventId])
  @@map("ticket_types")
}

model AdminApproval {
  id           String         @id @default(cuid())
  type         ApprovalType
  action       ApprovalAction @default(PENDING)
  reason       String?
  notes        String?
  metadata     Json?

  requesterId  String         @map("requester_id")
  reviewerId   String?        @map("reviewer_id")
  eventId      String?        @map("event_id")

  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  requester    User           @relation("ApprovalRequester", fields: [requesterId], references: [id])
  reviewer     User?          @relation("ApprovalReviewer", fields: [reviewerId], references: [id])
  event        Event?         @relation(fields: [eventId], references: [id])

  @@index([type, action])
  @@map("admin_approvals")
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique @map("user_id")
  expiresAt DateTime?  @map("expires_at")

  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@map("carts")
}

model CartItem {
  id           String     @id @default(cuid())
  quantity     Int
  cartId       String     @map("cart_id")
  ticketTypeId String     @map("ticket_type_id")

  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  cart         Cart       @relation(fields: [cartId], references: [id], onDelete: Cascade)
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id])

  @@unique([cartId, ticketTypeId])
  @@map("cart_items")
}

model Order {
  id                String      @id @default(cuid())
  orderNumber       String      @unique @map("order_number")
  status            OrderStatus @default(PENDING)
  subtotal          Decimal     @db.Decimal(10, 2) @default(0) @map("subtotal")
  platformFee       Decimal     @db.Decimal(10, 2) @default(0) @map("platform_fee")
  platformFeePercent Decimal    @db.Decimal(5, 2) @default(0) @map("platform_fee_percent")
  totalAmount       Decimal     @db.Decimal(10, 2) @map("total_amount")
  orgCommission     Decimal     @db.Decimal(10, 2) @default(0) @map("org_commission")
  orgCommissionPercent Decimal  @db.Decimal(5, 2) @default(0) @map("org_commission_percent")
  orgCommissionType String?     @map("org_commission_type")
  orgPayout         Decimal     @db.Decimal(10, 2) @default(0) @map("org_payout")
  convenienceFee    Decimal     @db.Decimal(10, 2) @default(0) @map("convenience_fee")
  convenienceFeeType String?    @map("convenience_fee_type")
  currency          String      @default("INR")
  guestEmail        String?     @map("guest_email")
  guestName         String?     @map("guest_name")
  guestPhone        String?     @map("guest_phone")

  userId            String?     @map("user_id")

  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  expiresAt      DateTime?   @map("expires_at")

  attendeeData   Json?       @map("attendee_data")
  invoiceUrl     String?     @map("invoice_url")

  user           User?       @relation(fields: [userId], references: [id])
  items          OrderItem[]
  tickets        Ticket[]
  payment        Payment?
  platformReview PlatformReview?
  eventReviews   EventReview[]

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id           String     @id @default(cuid())
  quantity     Int
  unitPrice    Decimal    @db.Decimal(10, 2) @map("unit_price")
  totalPrice   Decimal    @db.Decimal(10, 2) @map("total_price")

  orderId      String     @map("order_id")
  ticketTypeId String     @map("ticket_type_id")
  eventId      String     @map("event_id")

  createdAt    DateTime   @default(now()) @map("created_at")

  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id])
  event        Event      @relation(fields: [eventId], references: [id])
  tickets      Ticket[]

  @@map("order_items")
}

model Payment {
  id                String        @id @default(cuid())
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("INR")
  status            PaymentStatus @default(PENDING)
  provider          String        @default("manual")
  providerPaymentId String?       @map("provider_payment_id")
  providerOrderId   String?       @map("provider_order_id")
  metadata          Json?
  failureReason     String?       @map("failure_reason")

  orderId           String        @unique @map("order_id")

  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  order             Order         @relation(fields: [orderId], references: [id])

  @@index([providerPaymentId])
  @@map("payments")
}

model Ticket {
  id            String       @id @default(cuid())
  ticketCode    String       @unique @map("ticket_code")
  status        TicketStatus @default(ACTIVE)
  attendeeName  String       @map("attendee_name")
  attendeeEmail String       @map("attendee_email")
  attendeePhone String       @map("attendee_phone")
  qrData        String       @map("qr_data")
  qrDataUrl     String?      @map("qr_data_url") @db.Text
  checkedInAt   DateTime?    @map("checked_in_at")

  orderItemId   String       @map("order_item_id")
  orderId       String       @map("order_id")

  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  orderItem     OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  order         Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([orderItemId])
  @@index([ticketCode])
  @@map("tickets")
}

model Plan {
  id                 String   @id @default(cuid())
  tier               String   @unique
  name               String
  price              Decimal  @db.Decimal(10, 2)
  maxEventsPerMonth  Int      @map("max_events_per_month")
  maxTicketTiers     Int      @map("max_ticket_tiers")
  maxTicketsPerEvent Int      @map("max_tickets_per_event")
  maxStaffAccounts   Int      @map("max_staff_accounts")
  commissionPercent  Decimal  @db.Decimal(5, 2) @map("commission_percent")
  commissionType     String   @default("PERCENTAGE") @map("commission_type")
  features           String[] @default([])
  isActive           Boolean  @default(true) @map("is_active")
  sortOrder          Int      @default(0) @map("sort_order")

  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  subscriptions      OrgSubscription[]
  subscriptionPayments SubscriptionPayment[]

  @@map("plans")
}

model OrgSubscription {
  id                 String             @id @default(cuid())
  tier               SubscriptionTier   @default(FREE)
  status             SubscriptionStatus @default(ACTIVE)
  maxEvents          Int                @map("max_events")
  maxTickets         Int                @map("max_tickets")
  maxTicketTiers     Int                @default(2) @map("max_ticket_tiers")
  maxStaffAccounts   Int                @default(1) @map("max_staff_accounts")
  commissionPercent  Decimal            @db.Decimal(5, 2) @default(4.00) @map("commission_percent")
  commissionType     String             @default("PERCENTAGE") @map("commission_type")
  price              Decimal            @db.Decimal(10, 2) @default(0)
  startDate          DateTime           @map("start_date")
  endDate            DateTime?          @map("end_date")

  userId             String             @map("user_id")
  planId             String?            @map("plan_id")
  scheduledPlanId    String?            @map("scheduled_plan_id")
  scheduledPlanTier  String?            @map("scheduled_plan_tier")

  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  user               User               @relation(fields: [userId], references: [id])
  plan               Plan?              @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([userId, status])
  @@map("org_subscriptions")
}

model SubscriptionPayment {
  id                String        @id @default(cuid())
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("INR")
  status            PaymentStatus @default(PENDING)
  provider          String        @default("manual")
  providerPaymentId String?       @map("provider_payment_id")
  providerOrderId   String?       @map("provider_order_id")
  metadata          Json?
  failureReason     String?       @map("failure_reason")

  userId            String        @map("user_id")
  planId            String        @map("plan_id")
  tier              String
  activateNow       Boolean       @default(true) @map("activate_now")

  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  user              User          @relation(fields: [userId], references: [id])
  plan              Plan          @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([providerOrderId])
  @@map("subscription_payments")
}

model StaffAccount {
  id            String           @id @default(cuid())
  accessLevel   StaffAccessLevel @map("access_level")
  isActive      Boolean          @default(true) @map("is_active")

  organiserId   String           @map("organiser_id")
  userId        String           @map("user_id")

  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  organiser     User             @relation("OrganiserStaff", fields: [organiserId], references: [id])
  user          User             @relation("StaffUser", fields: [userId], references: [id])

  @@unique([organiserId, userId])
  @@index([userId])
  @@map("staff_accounts")
}

model ContentPage {
  id        String   @id @default(cuid())
  slug      String
  audience  String
  title     String
  content   String   @db.Text
  isActive  Boolean  @default(true) @map("is_active")

  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([slug, audience])
  @@map("content_pages")
}

model ConvenienceFeeSlab {
  id        String   @id @default(cuid())
  minAmount Decimal  @db.Decimal(10, 2) @map("min_amount")
  maxAmount Decimal? @db.Decimal(10, 2) @map("max_amount")
  feeType   String   @map("fee_type")
  feeValue  Decimal  @db.Decimal(10, 2) @map("fee_value")
  isActive  Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("convenience_fee_slabs")
}

// ─── PLATFORM REVIEWS ───────────────────────────────

model PlatformReview {
  id          String       @id @default(cuid())
  rating      Int
  title       String?
  content     String       @db.Text
  status      ReviewStatus @default(PENDING)
  isVisible   Boolean      @default(false) @map("is_visible")
  adminNotes  String?      @map("admin_notes")
  reviewedBy  String?      @map("reviewed_by")
  reviewedAt  DateTime?    @map("reviewed_at")

  userId      String       @map("user_id")
  orderId     String       @unique @map("order_id")

  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id])
  order       Order        @relation(fields: [orderId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([isVisible])
  @@map("platform_reviews")
}

// ─── EVENT REVIEWS ──────────────────────────────────

model EventReview {
  id          String       @id @default(cuid())
  rating      Int
  title       String?
  content     String       @db.Text
  isVisible   Boolean      @default(true) @map("is_visible")

  userId      String       @map("user_id")
  eventId     String       @map("event_id")
  orderId     String       @map("order_id")

  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id])
  event       Event        @relation(fields: [eventId], references: [id])
  order       Order        @relation(fields: [orderId], references: [id])

  @@unique([userId, eventId])
  @@index([eventId])
  @@index([isVisible])
  @@map("event_reviews")
}
